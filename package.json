{
  "name": "silver-music-notifier",
  "version": "0.1.0",
  "description": "Track artists and get notified of their new music releases from MusicBrainz, via CLI or a local web UI.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "silver-music-notifier": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"tsx watch src/cli/index.ts web --no-open\" \"vite\"",
    "build": "npm run build:bundle && npm run build:web",
    "build:bundle": "tsup",
    "build:web": "vite build",
    "prepare": "husky && npm run build",
    "refresh": "tsx src/cli/index.ts refresh",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md,html}": "prettier --write"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "better-sqlite3": "^11.7.0",
    "commander": "^13.0.0",
    "env-paths": "^3.0.0",
    "express": "^4.21.2",
    "musicbrainz-api": "^1.2.1",
    "node-notifier": "^10.0.1",
    "nodemailer": "^6.9.16",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/node-notifier": "^8.0.5",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "silver-ui": "^0.6.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
